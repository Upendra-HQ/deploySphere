# =====================================================================
# DeploySphere production environment (IP-only launch, no domain yet).
# Copy this to .env.production on the EC2 host and fill in every value
# marked CHANGE-ME. Generate strong secrets with:
#   openssl rand -base64 32
# =====================================================================

POSTGRES_USER=deploysphere_admin
POSTGRES_PASSWORD=CHANGE-ME-strong-postgres-password
POSTGRES_DB=deploysphere_prod

DATABASE_URL=postgresql://deploysphere_admin:CHANGE-ME-strong-postgres-password@postgres-db:5432/deploysphere_prod?schema=public
JWT_SECRET=CHANGE-ME-long-random-jwt-secret

# --- Host addresses -----------------------------------------------------
# No domain yet: frontend and API are served from the SAME EC2 public IP
# via the nginx-gateway container (/ -> frontend, /api/ -> backend).
# Replace <EC2_PUBLIC_IP> below with your instance's public IPv4.
# NOTE: if this is a plain public IP (not an Elastic IP), it changes
# every time the instance stops/starts -- and VITE_API_BASE_URL/VITE_WS_URL
# are baked into the frontend at build time, so an IP change means you
# must rebuild (and re-push, for the Jenkins flow) the frontend image.
# Attach an Elastic IP to avoid this.
FRONTEND_URL=http://<EC2_PUBLIC_IP>
BACKEND_URL=http://<EC2_PUBLIC_IP>
CORS_ORIGINS=http://<EC2_PUBLIC_IP>

# Docker Hub namespace/org used by Jenkinsfile.prod and docker-compose.prod.yml image: tags.
DOCKERHUB_NAMESPACE=your-dockerhub-username

# --- Email (Gmail SMTP) --------------------------------------------------
# Gmail blocks plain account passwords for SMTP login. You need a
# 16-character "App Password":
#   Google Account -> Security -> 2-Step Verification (must be ON)
#   -> App passwords -> generate one for "Mail" / "Other (DeploySphere)"
# Use that app password below, NOT your normal Gmail password.
EMAIL_SERVICE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-project-account@gmail.com
SMTP_PASS=CHANGE-ME-16-char-app-password
SMTP_FROM=your-project-account@gmail.com

# --- GitHub OAuth (optional) ---------------------------------------------
# Leave blank to run in mock mode (users paste repo URLs manually instead
# of connecting GitHub). Fill in only if you set up a GitHub OAuth App.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://<EC2_PUBLIC_IP>/api/github/callback

# --- Frontend build-time vars ---------------------------------------------
# WARNING: these are baked into the frontend bundle at BUILD time, not read
# at container start. Changing them requires a rebuild (and re-push, for the
# Jenkins pull-based flow) of the frontend image -- restarting the container
# alone will NOT pick up a new value.
# VITE_WS_URL must include the /api path: nginx only forwards WebSocket
# upgrade requests to the backend on /api/, and the backend's WebSocket
# server has no path restriction, so ws://<ip>/api works correctly.
VITE_API_BASE_URL=http://<EC2_PUBLIC_IP>
VITE_WS_URL=ws://<EC2_PUBLIC_IP>/api

# --- Monitoring (optional, run with --profile monitoring) ---------------
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
NODE_EXPORTER_URL=http://node-exporter:9100
CADVISOR_URL=http://cadvisor:8080
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE-ME-grafana-password
